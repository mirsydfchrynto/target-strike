# This .gitignore file is optimized for Unity project
#
# Recommended: Unity Project Settings > Editor > Version Control Mode > Visible Meta Files
# Recommended: Unity Project Settings > Editor > Asset Serialization Mode > Force Text
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/
/[Uu]serSettings/

# Asset meta files must be tracked
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the AssetStoreTools folder
# /[Aa]ssets/AssetStoreTools*

# Autogenerated VS/VSCode/Rider project files
ExportedObj/
.vs/
.gradle/
Export/
/*.csproj
/*.unityproj
/*.sln
/*.suo
/*.tmp
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.pdb
/*.mdb
/*.opendb
/*.db
/*.opendb.bak

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Builds
*.apk
*.unitypackage

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
